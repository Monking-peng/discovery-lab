# Copy this file to .env. Never commit the real .env file.

# Application
APP_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
LOG_LEVEL=INFO

# PostgreSQL + pgvector
POSTGRES_USER=discovery
POSTGRES_PASSWORD=discovery_dev_only
POSTGRES_DB=discovery_lab
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://discovery:discovery_dev_only@127.0.0.1:5432/discovery_lab

# Redis: queue delivery and short-lived coordination only
REDIS_PASSWORD=discovery_dev_only
REDIS_PORT=6379
REDIS_URL=redis://:discovery_dev_only@localhost:6379/0

# Immutable source blobs. Start locally; switch the adapter to S3/R2 for deployment.
BLOB_BACKEND=filesystem
BLOB_ROOT=./var/blobs
S3_ENDPOINT_URL=
S3_REGION=auto
S3_BUCKET=discovery-lab
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Model provider. Keep provider/model choice in versioned model profiles, not prompts.
LLM_PROVIDER=openai
EVIDENCE_EXTRACTOR=demo
OPENAI_MODEL=gpt-5.6-luna
OPENAI_API_KEY=
EVIDENCE_PROMPT_VERSION=evidence-extraction.v1
ANTHROPIC_API_KEY=
LANGGRAPH_STRICT_MSGPACK=true

# Optional observability. The product database still owns authoritative run records.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
OTEL_EXPORTER_OTLP_ENDPOINT=
